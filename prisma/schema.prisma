generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Platform {
  IOS
  ANDROID
  CROSS_PLATFORM
}

enum AssetType {
  DESCRIPTION
  KEYWORDS
  SCREENSHOT_CAPTIONS
  UPDATE_NOTES
  LOCALIZATION
}

// Backward-compatible alias retained while moving to AssetType.
enum GenerationType {
  DESCRIPTION
  KEYWORDS
  SCREENSHOT_CAPTIONS
  UPDATE_NOTES
  LOCALIZATION
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum GenerationStatus {
  PENDING
  SUCCEEDED
  FAILED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  projects     Project[]
  sessions     Session[]
  usageLogs    UsageLog[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Project {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  appName           String
  platform          Platform
  category          String
  status            ProjectStatus      @default(DRAFT)
  appSummary        String             @db.Text
  targetAudience    String             @db.Text
  toneOfVoice       String
  primaryLanguage   String
  competitors       String[]
  importantKeywords String[]
  features          ProjectFeature[]
  locales           ProjectLocale[]
  generationResults GenerationResult[]
  usageLogs         UsageLog[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([userId])
  @@index([status])
}

model ProjectFeature {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  value     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model ProjectLocale {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, code])
  @@index([projectId])
}

model GenerationResult {
  id        String           @id @default(cuid())
  projectId String
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      AssetType
  status    GenerationStatus @default(PENDING)
  version   Int              @default(1)
  locale    String?
  prompt    String           @db.Text
  model     String
  content   Json
  error     String?          @db.Text
  generatedAt DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([projectId, type, generatedAt])
  @@index([status])
  @@unique([projectId, type, locale, version])
}

model UsageLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  action       String
  status       String
  model        String?
  latencyMs    Int?
  inputTokens  Int?
  outputTokens Int?
  metadata     Json?
  error        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([projectId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, expiresAt])
}
