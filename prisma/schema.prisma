generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Platform {
  IOS
  ANDROID
  CROSS_PLATFORM
}

enum GenerationType {
  DESCRIPTION
  KEYWORDS
  SCREENSHOT_CAPTIONS
  UPDATE_NOTES
  LOCALIZATION
}

model User {
  id         String     @id @default(cuid())
  email      String     @unique
  name       String?
  projects   Project[]
  usageLogs  UsageLog[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Project {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  appName           String
  platform          Platform
  category          String
  appSummary        String             @db.Text
  targetAudience    String             @db.Text
  toneOfVoice       String
  primaryLanguage   String
  competitors       String[]
  importantKeywords String[]
  features          ProjectFeature[]
  locales           ProjectLocale[]
  generationResults GenerationResult[]
  usageLogs         UsageLog[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([userId])
}

model ProjectFeature {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  value     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([projectId])
}

model ProjectLocale {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code      String
  createdAt DateTime @default(now())

  @@unique([projectId, code])
  @@index([projectId])
}

model GenerationResult {
  id          String         @id @default(cuid())
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        GenerationType
  locale      String?
  prompt      String         @db.Text
  model       String
  content     Json
  generatedAt DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([projectId, type, generatedAt])
}

model UsageLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  action      String
  status      String
  model       String?
  latencyMs   Int?
  inputTokens Int?
  outputTokens Int?
  error       String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([projectId])
}
